# Jira Cloud
JIRA_SITE=https://your-tenant.atlassian.net
JIRA_EMAIL=symphony-agent@example.com
JIRA_API_TOKEN=replace-with-jira-api-token
JIRA_PROJECT_KEY=ABC
JIRA_JQL=project = ABC AND labels in (symphony) AND status in ("Ready for Agent", "Rework") ORDER BY priority DESC, updated ASC

# Source repository cloned into each issue workspace.
# Use an HTTPS URL for the first Docker smoke test unless the container has SSH credentials.
SOURCE_REPO_URL=https://github.com/your-org/your-repo.git
SOURCE_REPO_REF=main

# Symphony runtime inside the container.
SYMPHONY_HOST=0.0.0.0
SYMPHONY_PORT=4000
SYMPHONY_WORKSPACE_ROOT=/workspaces
SYMPHONY_LOGS_ROOT=/logs
SYMPHONY_AGENT_MODE=dry_run

# Host paths mounted by docker compose.
SYMPHONY_HOST_WORKSPACE_ROOT=./var/workspaces
SYMPHONY_HOST_LOGS_ROOT=./var/logs

# Codex runtime command. The Docker image does not install Codex yet; provide it in the runtime
# environment before dispatching real agent work.
CODEX_COMMAND=codex app-server
